{
  "name": "FocusRuddy",
  "description": "The Chrome Productivity Tool - Yes, we will be stealing your data.",
  "version": "6.7",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon48.png",
      "32": "images/icon48.png",
      "48": "images/icon48.png",
      "128": "images/icon48.png"
    }
  },
  "icons": {
    "16": "images/icon48.png",
    "32": "images/icon48.png",
    "48": "images/icon48.png",
    "128": "images/icon48.png"
  },
  "background": {
    "service_worker": "/code/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["/code/maze.js", "/code/wordle.js", "/code/zip.js", "/code/queens.js", "/code/distractions.js"]
    }
  ]
  
}
